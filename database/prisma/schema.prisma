generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = "file:./sovereign.db"
}

model Identity {
  id        Int @id @default(autoincrement())
  wallet    String @unique
  network   String @default("Base")
  score     Int @default(50)
  label     String @default("Neutral")
  sybilRisk Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  credentials Credential[]
  scans Scan[]
}

model Credential {
  id         Int @id @default(autoincrement())
  type       String
  value      String
  identityId Int
  identity   Identity @relation(fields:[identityId], references:[id])
}

model Scan {
  id         Int @id @default(autoincrement())
  wallet     String
  result     String
  createdAt  DateTime @default(now())

  identityId Int?
  identity   Identity? @relation(fields:[identityId], references:[id])
}

model ApiKey {
  id        Int @id @default(autoincrement())
  key       String @unique
  owner     String
  createdAt DateTime @default(now())
}
